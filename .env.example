# ===========================================
# 硫磺价格预测系统 - 环境变量配置
# ===========================================

# -------------------------------------------
# 数据库配置 (PostgreSQL) - 必需
# -------------------------------------------
# Vercel 推荐使用: Neon, Supabase, PlanetScale
# Neon 免费版: https://neon.tech
# Supabase 免费版: https://supabase.com
DATABASE_URL=postgresql://用户名:密码@主机:5432/数据库名

# -------------------------------------------
# 认证配置 (Better Auth) - 必需
# -------------------------------------------
# 部署到 Vercel 时，改为你的 Vercel 域名
BETTER_AUTH_URL=https://你的项目名.vercel.app

# -------------------------------------------
# AI API 配置 - 必需 (二选一)
# -------------------------------------------
# 方式1: OpenRouter (推荐，支持多种模型)
# 获取地址: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxx

# 方式2: OpenAI 兼容 API (如 DeepSeek、QnAI 等)
OPENAI_API_KEY=sk-xxxxx
OPENAI_BASE_URL=https://api.openai.com/v1

# -------------------------------------------
# 外部数据 API - 可选
# -------------------------------------------
# FRED 经济数据 API (免费)
# 获取地址: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=xxxxx

# -------------------------------------------
# 对象存储 (S3/R2) - 可选，用于文件上传
# -------------------------------------------
# Cloudflare R2 (推荐，免费额度大)
# R2_ACCESS_KEY_ID=xxxxx
# R2_SECRET_ACCESS_KEY=xxxxx
# R2_BUCKET_NAME=your-bucket
# R2_ACCOUNT_ID=xxxxx
# R2_PUBLIC_URL=https://your-bucket.your-account.r2.cloudflarestorage.com

# AWS S3
# AWS_ACCESS_KEY_ID=xxxxx
# AWS_SECRET_ACCESS_KEY=xxxxx
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=your-bucket

# -------------------------------------------
# 邮件服务 - 可选，用于邮件验证
# -------------------------------------------
# Resend (推荐，免费额度)
# 获取地址: https://resend.com
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=noreply@yourdomain.com

# -------------------------------------------
# 短信服务 - 可选，用于手机登录
# -------------------------------------------
# Twilio (推荐，国际短信)
# 获取地址: https://www.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+1234567890

# -------------------------------------------
# Node 环境
# -------------------------------------------
NODE_ENV=production

# -------------------------------------------
# Neo4j 图数据库 - 可选，用于知识图谱
# -------------------------------------------
# Neo4j 连接 URI (本地: bolt://localhost:7687, Aura: bolt+s://xxx.databases.neo4j.io)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password
# Neo4j Aura 云服务: https://neo4j.com/cloud/aura/

# -------------------------------------------
# 公开配置 (客户端可访问)
# -------------------------------------------
NEXT_PUBLIC_APP_URL=https://你的项目名.vercel.app